# Copy this file to .env and fill in your values
# cp .env.example .env

# Grafana admin password — change this before first run
GRAFANA_ADMIN_PASSWORD=changeme

# IP address of your Synology NAS on the LAN
NAS_IP=192.168.1.XXX

# ── Daily Gaming Report ─────────────────────────────────────────
# Copy this section to .env when you enable the report.

# Loki instance (do not change — this is the local NAS Loki)
LOKI_URL=http://192.168.1.5:3100

# Comma-separated list of child device names (exact match).
# Used to filter the report to relevant devices only.
# Example: CHILD_DEVICES=Ethan PC,EthanR-PC
CHILD_DEVICES=

# Timezone for report timestamps (IANA timezone name)
REPORT_TIMEZONE=Australia/Sydney

# SMTP settings — use any SMTP provider (Gmail, SendGrid, Fastmail, etc.)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your-smtp-username
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=home-network@example.com
# Comma-separated for multiple recipients
SMTP_TO=parent@example.com
# Set to "true" for port 587 (STARTTLS), "false" for port 465 (SSL)
SMTP_USE_TLS=true
