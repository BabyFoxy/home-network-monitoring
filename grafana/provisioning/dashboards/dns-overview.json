            "desc": true,
            "displayName": "Gaming Hits (24h)"
          }
        ]
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "orange"
          },
          "custom": {
            "align": "auto",
