                    {
                      "color": "orange",
                      "value": 50
                    },
                    {
                      "color": "red",
                      "value": 200
                    }
                  ]
                }
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "sum by (client_name) (count_over_time({job=\"adguard\"} |~ \"roblox|rbxcdn|rbxusercontent|bloxd[.]io|mojang|minecraft|crazygames|poki[.]com|now[.]gg|itch[.]io|lagged[.]com|gameflare|friv[.]com|y8[.]com|miniclip|kizi[.]com\" [24h]))",
          "legendFormat": "",
