{
  "title": "DNS — Parental Review",
  "uid": "dns-log-viz-v1",
  "schemaVersion": 39,
  "version": 6,
  "refresh": "5m",
  "time": { "from": "now-24h", "to": "now" },
  "description": "DNS evidence for gaming-related activity. Matches strongly suggest gaming-related behaviour but do not prove active gameplay with certainty.",
  "templating": {
    "list": [
      {
        "name": "client_name",
        "label": "Child Device",
        "type": "query",
        "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
        "query": "label_values({job=\"adguard\"}, client_name)",
        "includeAll": true,
        "allValue": ".+",
        "multi": true,
        "refresh": 2,
        "sort": 1,
        "current": {}
      },
      {
        "name": "domain_search",
        "label": "Domain filter",
        "type": "textbox",
        "query": "",
        "current": { "value": "" }
      }
    ]
  },
  "panels": [

    {
      "id": 10,
      "title": "Note",
      "type": "text",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 2 },
      "options": {
        "mode": "markdown",
        "content": "**DNS evidence** can strongly suggest gaming-related behaviour, but does not prove active gameplay with 100% certainty. Use this dashboard as a starting point for review conversations, not as absolute proof."
      }
    },

    {
      "id": 1,
      "title": "Gaming Activity Score by Device  (24h)",
      "description": "Gaming-related DNS queries per device in the past 24 hours. Count includes confirmed gaming and web-gaming domains. Higher = more activity.",
      "type": "table",
      "gridPos": { "x": 0, "y": 2, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "options": {
        "showHeader": true,
        "footer": { "show": false },
        "sortBy": [ { "desc": true, "displayName": "Gaming Hits (24h)" } ]
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "orange" },
          "custom": { "align": "auto", "cellOptions": { "type": "color-background" } },
          "unit": "none",
          "displayName": "Gaming Hits (24h)"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Time" },
            "properties": [
              { "id": "custom.hidden", "value": true }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "client_name" },
            "properties": [
              { "id": "displayName", "value": "Device" },
              { "id": "custom.cellOptions", "value": { "type": "text" } }
            ]
          },
          {
            "matcher": { "id": "byRegexp", "options": "Value.*" },
            "properties": [
              { "id": "displayName", "value": "Gaming Hits (24h)" },
              { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "gradient" } },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 50 }, { "color": "red", "value": 200 } ] } }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "sum by (client_name) (count_over_time({job=\"adguard\"} |~ \"roblox|rbxcdn|rbxusercontent|blox[.]io|mojang|minecraft|crazygames|poki[.]com|now[.]gg|itch[.]io|lagged[.]com|gameflare|friv[.]com|y8[.]com|miniclip|kizi[.]com\" [24h]))",
          "legendFormat": "",
          "queryType": "instant",
          "refId": "A"
        }
      ]
    },

    {
      "id": 2,
      "title": "Top Game Domains  (24h, selected devices)",
      "description": "Gaming-related domains queried by the selected devices in the past 24 hours. Count = number of DNS lookups per domain.",
      "type": "table",
      "gridPos": { "x": 12, "y": 2, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "options": {
        "showHeader": true,
        "footer": { "show": false },
        "sortBy": [ { "desc": true, "displayName": "Hits" } ]
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" },
          "custom": { "align": "auto", "cellOptions": { "type": "color-background" } },
          "unit": "none"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Time" },
            "properties": [
              { "id": "custom.hidden", "value": true }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "domain" },
            "properties": [
              { "id": "displayName", "value": "Domain" },
              { "id": "custom.cellOptions", "value": { "type": "text" } }
            ]
          },
          {
            "matcher": { "id": "byRegexp", "options": "Value.*" },
            "properties": [
              { "id": "displayName", "value": "Hits" },
              { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "gradient" } },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 10 }, { "color": "red", "value": 100 } ] } }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "sum by (domain) (count_over_time({job=\"adguard\", client_name=~\"$client_name\"} |~ \"roblox|rbxcdn|rbxusercontent|blox[.]io|mojang|minecraft|crazygames|poki[.]com|now[.]gg|itch[.]io|lagged[.]com|gameflare|friv[.]com|y8[.]com|miniclip|kizi[.]com\" | regexp \"-> (?P<domain>[^ ]+)\" [24h]))",
          "legendFormat": "",
          "queryType": "instant",
          "refId": "A"
        }
      ]
    },

    {
      "id": 3,
      "title": "Gaming Activity Timeline  (zoom time range to study hours e.g. 3pm–7pm)",
      "description": "Set the time range to study hours to see gaming during homework time. Each spike = cluster of gaming DNS queries in a 5-min window.",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 10, "w": 24, "h": 7 },
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        {
          "expr": "sum by (client_name) (count_over_time({job=\"adguard\", client_name=~\"$client_name\"} |~ \"roblox|rbxcdn|rbxusercontent|blox[.]io|mojang|minecraft|crazygames|poki[.]com|now[.]gg|itch[.]io|lagged[.]com|gameflare|friv[.]com|y8[.]com|miniclip|kizi[.]com\" [5m]))",
          "legendFormat": "🎮 {{client_name}}",
          "queryType": "range",
          "refId": "A"
        },
        {
          "expr": "sum by (client_name) (count_over_time({job=\"adguard\", client_name=~\"$client_name\"} |~ \"youtube[.]com|ytimg[.]com|googlevideo[.]com|discord[.]com|discordapp[.]com|discord[.]gg|twitch[.]tv\" [5m]))",
          "legendFormat": "📺 {{client_name}} (entertainment)",
          "queryType": "range",
          "refId": "B"
        }
      ]
    },

    {
      "id": 4,
      "title": "Burst Detection  (gaming DNS hits per 5-min window — sustained spikes suggest active play)",
      "description": "10+ gaming DNS hits in a 5-minute window is a strong indicator of an active game session. Orange = moderate, Red = high.",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 17, "w": 16, "h": 6 },
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 1, "fillOpacity": 20 },
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 5 },
              { "color": "red", "value": 15 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum by (client_name) (count_over_time({job=\"adguard\", client_name=~\"$client_name\"} |~ \"roblox|rbxcdn|rbxusercontent|blox[.]io|mojang|minecraft|crazygames|poki[.]com|now[.]gg|itch[.]io|lagged[.]com|gameflare|friv[.]com|y8[.]com|miniclip|kizi[.]com\" [5m]))",
          "legendFormat": "{{client_name}}",
          "queryType": "range",
          "refId": "A"
        }
      ]
    },

    {
      "id": 5,
      "title": "Gaming Queries Blocked  (24h)",
      "description": "Gaming-related DNS queries that AdGuard blocked (reason >= 3) in the past 24 hours, for the selected devices.",
      "type": "stat",
      "gridPos": { "x": 16, "y": 17, "w": 8, "h": 6 },
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "options": {
        "reduceOptions": { "calcs": ["sum"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 20 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"adguard\", client_name=~\"$client_name\", reason=~\"[3-9]\"} |~ \"roblox|rbxcdn|rbxusercontent|blox[.]io|mojang|minecraft|crazygames|poki[.]com|now[.]gg|itch[.]io|lagged[.]com|gameflare|friv[.]com|y8[.]com|miniclip|kizi[.]com\" [24h]))",
          "legendFormat": "",
          "queryType": "instant",
          "refId": "A"
        }
      ]
    },

    {
      "id": 6,
      "title": "Blocked Gaming Evidence  (24h, newest first)",
      "description": "Gaming-related DNS queries blocked by AdGuard (reason >= 3) in the past 24 hours. Each row = one blocked DNS lookup. Use Domain filter to search for a specific game or domain.",
      "type": "logs",
      "gridPos": { "x": 0, "y": 23, "w": 24, "h": 10 },
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "options": {
        "showTime": true,
        "wrapLogMessage": false,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      },
      "targets": [
        {
          "expr": "{job=\"adguard\", reason=~\"[3-9]\"} |~ \"roblox|rbxcdn|rbxusercontent|blox[.]io|mojang|minecraft|crazygames|poki[.]com|now[.]gg|itch[.]io|lagged[.]com|gameflare|friv[.]com|y8[.]com|miniclip|kizi[.]com\" |~ \"(?i)${domain_search:raw}\"",
          "queryType": "range",
          "refId": "A"
        }
      ]
    },

    {
      "id": 7,
      "title": "Entertainment Activity  (YouTube / Discord / Twitch — compare timing with gaming above)",
      "description": "Entertainment DNS queries from selected devices. Review alongside the gaming timeline to spot co-occurring activity — e.g. Discord open while gaming.",
      "type": "logs",
      "gridPos": { "x": 0, "y": 33, "w": 24, "h": 8 },
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "options": {
        "showTime": true,
        "wrapLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "signature"
      },
      "targets": [
        {
          "expr": "{job=\"adguard\", client_name=~\"$client_name\"} |~ \"youtube[.]com|ytimg[.]com|googlevideo[.]com|discord[.]com|discordapp[.]com|discord[.]gg|twitch[.]tv\" |~ \"(?i)${domain_search:raw}\"",
          "queryType": "range",
          "refId": "A"
        }
      ]
    },

    {
      "id": 8,
      "title": "School / Productivity Activity  (low activity here = no studying)",
      "description": "DNS queries matching known educational platforms. Low activity during study time is a useful contrast against gaming activity above.",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 41, "w": 24, "h": 6 },
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 1, "fillOpacity": 10 },
          "color": { "mode": "fixed", "fixedColor": "blue" }
        }
      },
      "targets": [
        {
          "expr": "sum by (client_name) (count_over_time({job=\"adguard\", client_name=~\"$client_name\"} |~ \"classroom[.]google|docs[.]google|drive[.]google|forms[.]google|office[.]com|sharepoint[.]com|onenote[.]com|schoology|khanacademy|duolingo\" [5m]))",
          "legendFormat": "📚 {{client_name}}",
          "queryType": "range",
          "refId": "A"
        }
      ]
    }

  ]
}
