{
  "title": "DNS Log Overview",
  "uid": "dns-log-viz-v1",
  "schemaVersion": 39,
  "version": 3,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "client_name",
        "label": "Device Name",
        "type": "query",
        "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
        "query": "label_values({job=\"adguard\"}, client_name)",
        "includeAll": true,
        "allValue": ".+",
        "multi": false,
        "refresh": 2,
        "sort": 1,
        "current": {}
      },
      {
        "name": "client",
        "label": "Device IP",
        "type": "query",
        "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
        "query": "label_values({job=\"adguard\"}, client)",
        "includeAll": true,
        "allValue": ".+",
        "multi": false,
        "refresh": 2,
        "sort": 1,
        "current": {}
      },
      {
        "name": "domain_search",
        "label": "Domain search",
        "type": "textbox",
        "query": "",
        "current": { "value": "" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "DNS Query Volume",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 7 },
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "targets": [
        {
          "expr": "sum by (client_name) (rate({job=\"adguard\", client=~\"$client\", client_name=~\"$client_name\"}[5m]))",
          "legendFormat": "{{client_name}}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 1, "fillOpacity": 10 }
        }
      },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "id": 2,
      "title": "Blocked Queries (reason≥3)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 7, "w": 12, "h": 6 },
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "targets": [
        {
          "expr": "sum by (client_name) (rate({job=\"adguard\", client=~\"$client\", client_name=~\"$client_name\", reason=~\"[3-9]\"}[5m]))",
          "legendFormat": "{{client_name}}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" },
          "custom": { "lineWidth": 1, "fillOpacity": 20 }
        }
      }
    },
    {
      "id": 3,
      "title": "Query Types",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 7, "w": 12, "h": 6 },
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "targets": [
        {
          "expr": "sum by (query_type) (rate({job=\"adguard\", client=~\"$client\", client_name=~\"$client_name\"}[5m]))",
          "legendFormat": "{{query_type}}",
          "queryType": "range",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "DNS Query Log",
      "type": "logs",
      "gridPos": { "x": 0, "y": 13, "w": 24, "h": 14 },
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "options": {
        "showTime": true,
        "wrapLogMessage": false,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      },
      "targets": [
        {
          "expr": "{job=\"adguard\", client=~\"$client\", client_name=~\"$client_name\"} |~ \"(?i)${domain_search:raw}\"",
          "queryType": "range",
          "refId": "A"
        }
      ]
    }
  ]
}
