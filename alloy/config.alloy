loki.write "default" {
  endpoint {
    url = "http://loki:3100/loki/api/v1/push"
  }
}

// ── AdGuard Home DNS query log ──────────────────────────────

local.file_match "adguard_querylog" {
  path_targets = [{ __path__ = "/adguard-logs/querylog.json" }]
  sync_period  = "5s"
}

loki.source.file "adguard_file" {
  targets               = local.file_match.adguard_querylog.targets
  forward_to            = [loki.process.adguard_parse.receiver]
  legacy_positions_file = "/tmp/alloy-positions.yaml"
}

loki.process "adguard_parse" {
  forward_to = [loki.write.default.receiver]

  stage.json {
    expressions = {
      event_time  = "T",
      domain      = "QH",
      query_type  = "QT",
      client      = "IP",
      upstream    = "Upstream",
      client_name = "CP",
    }
  }

  stage.regex {
    expression = `"Reason":(?P<reason>\d+)`
  }

  // Precedence: AdGuard CP (client_info.name) > udm-hosts.json lookup > raw IP
  // Dict is auto-generated by scripts/update-enrichment.sh — do not edit manually
  stage.template {
    source   = "client_name"
    template = `{{ if .client_name }}{{ .client_name }}{{ else }}{{ $m := dict "192.168.1.2" "homeassistant" "192.168.1.3" "Fox-PC" "192.168.1.10" "Ring-aa2240" "192.168.1.15" "ESP_BDEFC9" "192.168.1.16" "Reolink" "192.168.1.19" "Theatre-Room" "192.168.1.27" "EthanR-PC" "192.168.1.28" "MBP-S26226" "192.168.1.50" "SonosZP" "192.168.1.57" "DVR3211" "192.168.1.81" "lumi_gateway_mgl03" "192.168.1.85" "MXCHIP" "192.168.1.98" "Qingping-Air-Monitor-Lite" "192.168.1.101" "roborock-vacuum-a75" "192.168.1.103" "chuangmi-plug-m3" "192.168.1.107" "tvdfed8b641ea1" "192.168.1.108" "QCA4002" "192.168.1.110" "XBOX" "192.168.1.113" "tesla" "192.168.1.118" "amazon-c58229cd0" "192.168.1.127" "espressif" "192.168.1.135" "HS100" "192.168.1.156" "wenxiaodeiPhone" "192.168.1.162" "FoxsHomePodMini" "192.168.1.163" "iPhone" "192.168.1.184" "iPad" "192.168.1.208" "P100" "192.168.1.212" "amazon-86b9c06c6" "192.168.1.221" "deco-BE65" "192.168.1.251" "VMB4000" }}{{ $n := get $m .client }}{{ if $n }}{{ $n }}{{ else }}{{ .client }}{{ end }}{{ end }}`
  }

  stage.timestamp {
    source = "event_time"
    format = "RFC3339Nano"
  }

  stage.static_labels {
    values = {
      job    = "adguard",
      source = "dns_querylog",
    }
  }

  // ── Domain category classification ─────────────────────────
  // category: gaming | web_gaming | entertainment | school | system | unknown
  // Rules use explicit domain matches only — .io alone is NOT a signal.
  stage.template {
    source   = "category"
    template = `{{ $d := .domain }}{{ if or (contains "roblox" $d) (contains "rbxcdn" $d) (contains "rbxusercontent" $d) (contains "blox.io" $d) (contains "mojang" $d) (contains "minecraft" $d) }}gaming{{ else if or (contains "crazygames" $d) (contains "poki.com" $d) (contains "now.gg" $d) (contains "itch.io" $d) (contains "lagged.com" $d) (contains "gameflare" $d) (contains "friv.com" $d) (contains "y8.com" $d) (contains "miniclip" $d) (contains "kizi.com" $d) }}web_gaming{{ else if or (contains "youtube.com" $d) (contains "ytimg.com" $d) (contains "googlevideo.com" $d) (contains "discord.com" $d) (contains "discord.gg" $d) (contains "discordapp.com" $d) (contains "twitch.tv" $d) }}entertainment{{ else if or (contains "classroom.google" $d) (contains "docs.google" $d) (contains "drive.google" $d) (contains "forms.google" $d) (contains "office.com" $d) (contains "sharepoint.com" $d) (contains "onenote.com" $d) (contains "schoology" $d) (contains "canvas" $d) (contains "duolingo" $d) (contains "khanacademy" $d) }}school{{ else if or (contains "microsoft.com" $d) (contains "windowsupdate.com" $d) (contains "apple.com" $d) (contains "icloud.com" $d) (contains "akadns.net" $d) (contains "akamai" $d) (contains "cloudfront.net" $d) (contains "amazonaws.com" $d) (contains "gstatic.com" $d) (contains "googleapis.com" $d) }}system{{ else }}unknown{{ end }}`
  }

  stage.labels {
    values = {
      client      = "client",
      client_name = "client_name",
      query_type  = "query_type",
      reason      = "reason",
      category    = "category",
    }
  }

  stage.template {
    source   = "output"
    template = "{{ .client_name }} ({{ .client }}) -> {{ .domain }} [{{ .query_type }}] cat={{ .category }} reason={{ .reason }} upstream={{ .upstream }}"
  }

  stage.output {
    source = "output"
  }
}

// ── UDM SE syslog — RFC3164 BSD format ─────────────────────
// Raw format: <priority>Mon DD HH:MM:SS hostname process: message

loki.source.syslog "udm_raw" {
  listener {
    address  = "0.0.0.0:5514"
    protocol = "udp"
    syslog_format = "rfc3164"
    labels = {
      job    = "udm",
      source = "syslog",
    }
  }
  forward_to = [loki.write.default.receiver]
}
